// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id            String   @id @default(cuid())
  cluster       String   @default("ads")
  name          String
  nickname      String   @default("")
  position      String   @default("")
  email         String   @default("")
  password      String?
  birthDate     String?
  contactNumber String   @default("")
  photo         String?
  createdAt     DateTime @default(now())
  tasks         Task[]

  @@unique([cluster, name], name: "cluster_name")
  @@index([cluster])
}

model Task {
  id             String          @id @default(cuid())
  employeeId     String
  employee       Employee        @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date           String?
  dueDate        String?
  taskGeneral    String          @default("")
  taskDetails    String          @default("")
  status         String          @default("Pending")
  helpNeeded     String          @default("")
  createdAt      DateTime        @default(now())
  engagementTask EngagementTask?

  // Partner-escalation link: a blocker mentioning the partner auto-creates a
  // deliverable on the partner's sheet pointing back at the blocked task.
  blockerForTaskId String? @unique
  blockerForTask   Task?   @relation("BlockerLink", fields: [blockerForTaskId], references: [id], onDelete: Cascade)
  blockerTask      Task?   @relation("BlockerLink")

  @@index([employeeId])
}

model AuditIndex {
  id         String         @id @default(cuid())
  cluster    String
  clientName String         @default("")
  year       Int            @default(2025)
  pfrsType   String
  createdAt  DateTime       @default(now())
  sections   AuditSection[]

  @@index([cluster])
}

model AuditSection {
  id         String      @id @default(cuid())
  indexId    String
  index      AuditIndex  @relation(fields: [indexId], references: [id], onDelete: Cascade)
  name       String
  title      String      @default("")
  sectionRef String      @default("")
  sortOrder  Int         @default(0)
  isCustom   Boolean     @default(false)
  items      AuditItem[]
}

model AuditItem {
  id             String       @id @default(cuid())
  sectionId      String
  section        AuditSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  refNum         String
  description    String       @default("")
  initials       String       @default("")
  sourceDocument String       @default("")
  isNA           Boolean      @default(false)
  sortOrder      Int          @default(0)
}

model SpecialEngagement {
  id             String           @id @default(cuid())
  cluster        String
  companyName    String
  engagement     String
  proposalDate   DateTime
  dueDate        DateTime
  seniorAssigned String           @default("")
  juniorAssigned String[]
  status         String           @default("Ongoing")
  signedProposal     String?
  signedProposalName String?
  createdAt      DateTime         @default(now())
  tasks          EngagementTask[]

  @@index([cluster])
}

model EngagementTask {
  id           String            @id @default(cuid())
  engagementId String
  engagement   SpecialEngagement @relation(fields: [engagementId], references: [id], onDelete: Cascade)
  task         String            @default("")
  createdDate  DateTime          @default(now())
  dueDate      DateTime?
  status       String            @default("Pending")
  comments     String            @default("")
  sortOrder    Int               @default(0)
  assignedTo   String            @default("")
  linkedTaskId String?           @unique
  linkedTask   Task?             @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
}
